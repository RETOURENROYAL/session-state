# ── R3 n8n GitHub API Stack ─────────────────────────────────────────────
# Copy to .env and fill in values (NEVER commit .env)

# GitHub PAT with: repo, workflow, admin:org, codespace scopes
GITHUB_TOKEN=ghp_YOUR_TOKEN_HERE

# n8n instance URL (change if behind reverse proxy)
N8N_URL=http://localhost:5678
