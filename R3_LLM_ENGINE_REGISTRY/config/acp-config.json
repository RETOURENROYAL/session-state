  "quick_test_commands": {
    "_comment": "Run in PowerShell — verified working commands only",
    "_note": "All /acp commands removed — R3 servers do not implement ACP JSON-RPC. Use /mcp (SSE) and /v1/ (OpenAI) instead.",

    "STEP1_list_models": "(Invoke-RestMethod 'http://localhost:4000/v1/models' -Headers @{Authorization='Bearer r3-local'}).data | Select id",
    "STEP2_chat_auto_model": "$m=(Invoke-RestMethod 'http://localhost:4000/v1/models' -Headers @{Authorization='Bearer r3-local'}).data[0].id; Invoke-RestMethod -Method Post 'http://localhost:4000/v1/chat/completions' -Headers @{Authorization='Bearer r3-local';'Content-Type'='application/json'} -Body \"{`\"model`\":`\"$m`\",`\"messages`\":[{`\"role`\":`\"user`\",`\"content`\":`\"Ping`\"}],`\"max_tokens`\":5}\" | ConvertTo-Json",
    "STEP3_mcp_8420": "Invoke-WebRequest 'http://localhost:8420/mcp' -UseBasicParsing | Select StatusCode,StatusDescription",
    "STEP4_mcp_8421": "Invoke-WebRequest 'http://localhost:8421/mcp' -UseBasicParsing | Select StatusCode,StatusDescription",
    "STEP5_8422_probe": "@('/','/api','/status','/health','/engines') | ForEach-Object { try { $r=Invoke-WebRequest \"http://localhost:8422$_\" -TimeoutSec 3 -UseBasicParsing; Write-Host \"$_ => $($r.StatusCode)\" } catch { Write-Host \"$_ => ERR\" } }",
    "full_test_suite": "iwr 'https://raw.githubusercontent.com/RETOURENROYAL/session-state/main/R3_LLM_ENGINE_REGISTRY/scripts/Test-R3-ACP-MultiConnect.ps1' -OutFile \"$env:TEMP\\r3test.ps1\"; & \"$env:TEMP\\r3test.ps1\"",
    "install_mcp_config": "iwr 'https://raw.githubusercontent.com/RETOURENROYAL/session-state/main/R3_LLM_ENGINE_REGISTRY/scripts/Install-R3-VSCode-MCP.ps1' -OutFile \"$env:TEMP\\r3mcp.ps1\"; & \"$env:TEMP\\r3mcp.ps1\"",
    "start_all_servers": "iwr 'https://raw.githubusercontent.com/RETOURENROYAL/session-state/main/R3_LLM_ENGINE_REGISTRY/scripts/Start-R3-AllServers.ps1' -OutFile \"$env:TEMP\\r3start.ps1\"; & \"$env:TEMP\\r3start.ps1\""
