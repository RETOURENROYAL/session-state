{
  "_comment": "R3-DASHBOARD — Multi-Connection Workplace Config (MCP + LiteLLM + ACP reference)",
  "_spec": "https://agentclientprotocol.com",
  "_spec_index": "https://agentclientprotocol.com/llms.txt",
  "_protocol": "JSON-RPC 2.0",
  "_litellm_gateway": "http://localhost:4000/v1",
  "_updated": "2026-04-22",
  "_IMPORTANT": {
    "what_is_live": [
      "LiteLLM gateway :4000 — OpenAI-compatible API (/v1/models, /v1/chat/completions)",
      "ChatLegs :8420/:8421 — MCP SSE at /mcp (confirmed), OpenAI-proxy at /v1/chat/completions",
      "Matrix control :8422 — custom control-plane REST (no /mcp, no /acp)"
    ],
    "what_is_not_live": [
      "/acp endpoint — R3 servers do NOT implement the ACP JSON-RPC protocol natively",
      "ACP coding-agent protocol requires a dedicated ACP server (e.g. Claude Code, Copilot Workspace)",
      ":8422/mcp — returns 404, control plane does not expose MCP SSE"
    ],
    "acp_sections_below": "acp_agents / proxy_chain / mcp_over_acp are reference config for when an ACP-native agent is added"
  },

  "transports": {
    "_doc": "https://agentclientprotocol.com/protocol/transports.md",
    "stdio": {
      "description": "Agent as subprocess, communicates via stdin/stdout. Newline-delimited JSON-RPC. Supported by all agents.",
      "use_for": ["github-copilot-cli", "local-python-agents"],
      "notes": "stderr for logging only. stdout MUST only contain valid ACP messages."
    },
    "streamable-http": {
      "description": "HTTP-based transport (draft). For long-running server agents on known ports.",
      "use_for": ["future-acp-agent"],
      "notes": "R3 ChatLegs servers do NOT expose /acp. They expose /mcp (SSE) + OpenAI-compatible /v1/chat/completions."
    },
    "mcp-over-acp": {
      "description": "MCP servers tunnelled through ACP channel — no separate process.",
      "_rfd": "https://agentclientprotocol.com/rfds/mcp-over-acp.md",
      "transport_value": "acp",
      "notes": "Advertised by agent as mcpCapabilities.acp=true."
    }
  },

  "acp_agents": {
    "_doc": "https://agentclientprotocol.com/get-started/agents.md",

    "github-copilot-cli": {
      "description": "GitHub Copilot CLI as ACP agent (stdio)",
      "transport": "stdio",
      "command": "copilot",
      "auto_connect": true,
      "auth_required": false,
      "capabilities": {
        "fs": { "readTextFile": true, "writeTextFile": true },
        "terminal": true,
        "sessionCapabilities": { "list": {}, "load": {} },
        "providers": {}
      },
      "_note": "VS Code auto-connects when CWD = trusted workspace. Use /ide in CLI."
    },

    "r3-chatlegs-primary": {
      "description": "ChatLegs Primary proxy — ACP agent on :8420",
      "transport": "streamable-http",
      "endpoint": "http://localhost:8420/acp",
      "mcp_endpoint": "http://localhost:8420/mcp",
      "port": 8420,
      "status": "live",
      "auth": {
        "type": "env_var",
        "vars": [
          {
            "name": "R3_API_KEY",
            "label": "R3 API Key",
            "secret": true,
            "optional": true
          }
        ]
      },
      "capabilities": {
        "fs": { "readTextFile": true, "writeTextFile": true },
        "terminal": true,
        "providers": {},
        "sessionCapabilities": { "list": {}, "load": {} },
        "mcpCapabilities": { "acp": true }
      }
    },

    "r3-chatlegs-shadow": {
      "description": "ChatLegs Shadow — failover/load-balance on :8421",
      "transport": "streamable-http",
      "endpoint": "http://localhost:8421/acp",
      "mcp_endpoint": "http://localhost:8421/mcp",
      "port": 8421,
      "status": "live",
      "role": "shadow",
      "capabilities": {
        "fs": { "readTextFile": true, "writeTextFile": true },
        "terminal": true,
        "providers": {},
        "sessionCapabilities": { "list": {}, "load": {} }
      }
    },

    "r3-matrix-control": {
      "description": "Matrix Control Plane — orchestration/routing/conductor on :8422",
      "transport": "streamable-http",
      "endpoint": "http://localhost:8422/acp",
      "mcp_endpoint": "http://localhost:8422/mcp",
      "port": 8422,
      "status": "live",
      "role": "conductor",
      "_note": "Acts as ACP conductor for proxy-chain pattern.",
      "capabilities": {
        "fs": { "readTextFile": true, "writeTextFile": true },
        "terminal": true,
        "providers": {},
        "sessionCapabilities": { "list": {}, "load": {} },
        "mcpCapabilities": { "acp": true }
      }
    }
  },

  "proxy_chain": {
    "_doc": "https://agentclientprotocol.com/rfds/proxy-chains.md",
    "_comment": "r3-matrix-control acts as conductor. Proxies sit between client and base agent.",
    "conductor": "r3-matrix-control",
    "chain": [
      {
        "id": "context-proxy",
        "description": "Injects R3 workspace context + AGENTS.md into every prompt",
        "transport": "streamable-http",
        "endpoint": "http://localhost:8422/proxy/context",
        "proxy_method": "proxy/successor"
      },
      {
        "id": "tool-filter-proxy",
        "description": "Filters and routes tool calls to appropriate backend",
        "transport": "streamable-http",
        "endpoint": "http://localhost:8422/proxy/tools",
        "proxy_method": "proxy/successor"
      }
    ],
    "base_agent": "r3-chatlegs-primary",
    "flow": "Client → Conductor(:8422) → ContextProxy → ToolProxy → ChatLegs(:8420)"
  },

  "mcp_over_acp": {
    "_doc": "https://agentclientprotocol.com/rfds/mcp-over-acp.md",
    "_comment": "Inject MCP servers into sessions via ACP channel — no separate process needed.",
    "session_new_tools_block": {
      "mcpServers": {
        "r3-project-tools": {
          "transport": "acp",
          "id": "r3-project-tools-550e8400"
        },
        "r3-workspace-tools": {
          "transport": "acp",
          "id": "r3-workspace-tools-a1b2c3d4"
        }
      }
    },
    "mcp_connect_flow": {
      "step1": "Agent sends mcp/connect with acp_id → Client returns connectionId",
      "step2": "Agent sends mcp/message (tool calls routed back via ACP channel)",
      "step3": "Agent sends mcp/disconnect when done"
    }
  },

  "initialization": {
    "_doc": "https://agentclientprotocol.com/protocol/initialization.md",
    "full_handshake": {
      "step1_initialize": {
        "jsonrpc": "2.0",
        "id": 1,
        "method": "initialize",
        "params": {
          "protocolVersion": 1,
          "clientInfo": { "name": "r3-copilot-cli", "version": "1.0" },
          "capabilities": {
            "fs": { "readTextFile": true, "writeTextFile": true },
            "terminal": true
          },
          "workspaceRoots": [
            "C:\\Users\\mail\\R3-DASHBOARD",
            "C:\\Users\\mail\\R3-DASHBOARD\\SOURCE\\chat-legs",
            "C:\\Users\\mail\\R3-DASHBOARD\\MODULES"
          ]
        }
      },
      "step2_authenticate_if_required": {
        "_note": "Only if agentCapabilities.auth present in initialize response",
        "jsonrpc": "2.0",
        "id": 2,
        "method": "authenticate",
        "params": {
          "method": "env_var",
          "vars": { "R3_API_KEY": "${R3_API_KEY}" }
        }
      },
      "step3_providers_list": {
        "_note": "Only if agentCapabilities.providers present",
        "jsonrpc": "2.0",
        "id": 3,
        "method": "providers/list",
        "params": {}
      },
      "step4_providers_set": {
        "jsonrpc": "2.0",
        "id": 4,
        "method": "providers/set",
        "params": {
          "id": "main",
          "apiType": "openai",
          "baseUrl": "http://localhost:4000/v1",
          "headers": { "Authorization": "Bearer r3-local" }
        }
      }
    }
  },

