  "routing_rules": {
    "_description": "Task-type to model chain. First available model wins. LiteLLM prefix: ollama_chat/ (RAZER) or ollama_chat/192.168.1.226:11434/ (APPSEN).",

    "code": {
      "description": "Code generation, debugging, refactoring",
      "priority_chain": [
        "ollama_chat/deepseek-coder:6.7b",
        "ollama_chat/qwen2.5-coder:latest",
        "ollama_chat/codellama:7b",
        "ollama_chat/qwen3:latest"
      ],
      "fallback": "groq/llama-3.3-70b"
    },

    "reasoning": {
      "description": "Complex analysis, multi-step reasoning, research",
      "priority_chain": [
        "ollama_chat/deepseek-r1:latest",
        "ollama_chat/qwen3:latest",
        "ollama_chat/qwen2.5:14b",
        "ollama_chat/nemotron-cascade-2:latest"
      ],
      "fallback": "groq/llama-3.3-70b"
    },

    "fast": {
      "description": "Quick responses, autocomplete, lightweight tasks",
      "priority_chain": [
        "ollama_chat/gemma2:2b",
        "ollama_chat/qwen2.5:3b",
        "ollama_chat/nemotron-mini:latest",
        "ollama_chat/phi3:mini"
      ],
      "fallback": "groq/llama-3.1-8b"
    },

    "chat": {
      "description": "General chat, instruction following, Q&A",
      "priority_chain": [
        "ollama_chat/mistral:latest",
        "ollama_chat/llama3:8b",
        "ollama_chat/qwen2.5:7b",
        "ollama_chat/gemma4:latest"
      ],
      "fallback": "groq/llama-3.3-70b"
    },

    "large_context": {
      "description": "Long documents, large codebases, complex context",
      "priority_chain": [
        "ollama_chat/mixtral:latest",
        "ollama_chat/nemotron-cascade-2:latest",
        "ollama_chat/qwen2.5:14b"
      ],
      "fallback": "openrouter/auto"
    },

    "autocomplete": {
      "description": "Tab completion, fill-in-the-middle",
      "priority_chain": [
        "ollama_chat/phi3:mini",
        "ollama_chat/gemma2:2b",
        "ollama_chat/qwen2.5:3b"
      ],
      "fallback": "groq/llama-3.1-8b"
    },

    "embedding": {
      "description": "Vector embeddings for RAG, semantic search",
      "priority_chain": ["ollama/nomic-embed-text:latest@192.168.1.226:11434"],
      "note": "APPSEN only — nomic-embed-text is the ONLY embedding model in cluster"
    },

    "offline_fallback": {
      "description": "When internet/cloud unavailable — pure local",
      "priority_chain": [
        "ollama_chat/deepseek-r1:latest",
        "ollama_chat/qwen3:latest",
        "ollama_chat/mistral:latest",
        "ollama_chat/llama3:8b",
        "ollama_chat/gemma2:2b"
      ]
    }
  },

