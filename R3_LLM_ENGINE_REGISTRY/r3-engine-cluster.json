      "litellm-gateway → groq/llama-3.3-70b",
      "litellm-gateway → cerebras/llama-3.3-70b",
      "litellm-gateway → sambanova/llama-3.3-70b",
      "litellm-gateway → openrouter/auto",
      "ollama-razer → gemma2:2b",
      "ollama-appsen → llama3.2"
    ],
    "paid_engines": ["gpt-4o", "claude-3-5-sonnet", "gemini-2.0-flash"],
    "paid_use_condition": "Only when explicitly requested by user or task requires model capabilities unavailable in free tier",
    "gateway_endpoint": "http://localhost:4000/v1",
    "gateway_key": "r3-local",
    "ollama_endpoint": "http://localhost:11434",
    "autocomplete_model": "groq/llama-3.1-8b"
  },

  "mcp_servers": {
