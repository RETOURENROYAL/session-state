  "dependency_graph": {
    "_description": "Build and startup order for zero-cost local operation. Start engines first, then proxy layer, then control plane.",
    "startup_sequence": [
      {
        "step": 1,
        "id": "litellm-gateway",
        "type": "engine",
        "cmd": "litellm --config litellm-config.yaml --port 4000",
        "check": "curl http://localhost:4000/health",
        "required_for": [
          "02_ai_proxy_layer",
          "05_ki_api_service",
          "all agent tasks"
        ]
      },
      {
        "step": 2,
        "id": "ollama-razer",
        "type": "engine",
        "cmd": "ollama serve",
        "check": "curl http://localhost:11434/api/tags",
        "required_for": ["LOCAL-ONLY profile", "fallback chain"],
        "optional": true
      },
      {
        "step": 3,
        "id": "chatlegs-primary",
        "type": "mcp-server",
        "port": 8420,
        "depends_on": ["litellm-gateway"],
        "cmd": "node SOURCE/chat-legs/server.js",
        "required_for": ["02_ai_proxy_layer", "04_frontend_ui"]
      },
      {
        "step": 4,
        "id": "chatlegs-shadow",
        "type": "mcp-server",
        "port": 8421,
        "depends_on": ["litellm-gateway"],
        "required_for": ["02_ai_proxy_layer fallback"]
      },
      {
        "step": 5,
        "id": "matrix-control",
        "type": "mcp-server",
        "port": 8422,
        "depends_on": ["chatlegs-primary"],
        "required_for": ["03_control_plane"]
      }
    ],

