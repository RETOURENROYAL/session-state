{
  // R3-DASHBOARD — Zero-Cost Engine Orchestration
  // Master cluster: R3_LLM_ENGINE_REGISTRY/r3-engine-cluster.json
  // MCP servers:    R3_LLM_ENGINE_REGISTRY/config/mcp-servers.json
  // Node map:       r3-node-map.json

  "mcp": {
    "servers": {
      "r3-chatlegs-primary": {
        "type": "sse",
        "url": "http://localhost:8420/mcp"
      },
      "r3-chatlegs-shadow": {
        "type": "sse",
        "url": "http://localhost:8421/mcp"
      }
      // r3-matrix-control :8422 does not expose /mcp — omitted
    }
  },

  "continue.models": [
    {
      "title": "⚡ LiteLLM → Groq Llama 3.3 70B",
      "provider": "openai",
      "model": "groq/llama-3.3-70b",
      "apiBase": "http://localhost:4000/v1",
      "apiKey": "r3-local"
    },
    {
      "title": "⚡ LiteLLM → Cerebras 70B",
      "provider": "openai",
      "model": "cerebras/llama-3.3-70b",
      "apiBase": "http://localhost:4000/v1",
      "apiKey": "r3-local"
    },
    {
      "title": "⚡ LiteLLM → OpenRouter Auto",
      "provider": "openai",
      "model": "openrouter/auto",
      "apiBase": "http://localhost:4000/v1",
      "apiKey": "r3-local"
    },
    {
      "title": "🟢 Ollama RAZER — gemma2:2b",
      "provider": "ollama",
      "model": "gemma2:2b",
      "apiBase": "http://host.docker.internal:11434"
    },
    {
      "title": "💰 GPT-4o",
      "provider": "openai",
      "model": "gpt-4o",
      "apiBase": "http://localhost:4000/v1",
      "apiKey": "r3-local"
    },
    {
      "title": "💰 Claude 3.5 Sonnet",
      "provider": "openai",
      "model": "claude-3-5-sonnet",
      "apiBase": "http://localhost:4000/v1",
      "apiKey": "r3-local"
    }
  ],
  "continue.tabAutocompleteModel": {
    "title": "Autocomplete — Groq 8B",
    "provider": "openai",
    "model": "groq/llama-3.1-8b",
    "apiBase": "http://localhost:4000/v1",
    "apiKey": "r3-local"
  },
  "continue.enableTabAutocomplete": true,
  "continue.allowAnonymousTelemetry": false,
  "files.associations": {
    "*.json": "jsonc"
  },
  "editor.formatOnSave": false,

  // ── ACP (Agent Client Protocol) ─────────────────────────
  // GitHub Copilot CLI connects automatically when workspace is trusted.
  // Use /ide in CLI to manage VS Code connection + diff toggle.
  // ACP config: R3_LLM_ENGINE_REGISTRY/config/acp-config.json
  // providers/set routes ACP agent LLM calls → localhost:4000
  "github.copilot.advanced": {
    "debug.overrideProxyUrl": "http://localhost:4000/v1"
  },
  "github.copilot.chat.localeOverride": "de",
  "chat.agent.enabled": true,

  // ── R3 Platform Context ──────────────────────────────────
  // copilot-instructions.md gives Copilot Chat full R3 platform context.
  // Loaded automatically from .github/copilot-instructions.md in workspace root.
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,
  "github.copilot.chat.testGeneration.useInstructionFiles": true
}
