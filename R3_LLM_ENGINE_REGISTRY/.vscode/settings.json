{
  // R3-DASHBOARD — Zero-Cost Engine Orchestration
  // Master cluster: R3_LLM_ENGINE_REGISTRY/r3-engine-cluster.json
  // MCP servers:    R3_LLM_ENGINE_REGISTRY/config/mcp-servers.json
  // Node map:       r3-node-map.json

  "mcp": {
    "servers": {
      "r3-chatlegs-primary": {
        "type": "sse",
        "url": "http://localhost:8420/mcp"
      },
      "r3-chatlegs-shadow": {
        "type": "sse",
        "url": "http://localhost:8421/mcp"
      }
      // r3-matrix-control :8422 does not expose /mcp — omitted
    }
  },

  // ── Continue.dev Models — all via LiteLLM :4000 ─────────
  // r3/* routes = Ollama RAZER/APPSEN (zero-cost, local)
  // groq/cerebras = cloud free-tier fallbacks
  "continue.models": [
    // ── Local Ollama Routes (RAZER) ──────────────────────────
    {
      "title": "🔥 r3/code — deepseek-coder:6.7b",
      "provider": "openai",
      "model": "r3/code",
      "apiBase": "http://localhost:4000/v1",
      "apiKey": "r3-local"
    },
    {
      "title": "🔥 r3/reasoning — deepseek-r1",
      "provider": "openai",
      "model": "r3/reasoning",
      "apiBase": "http://localhost:4000/v1",
      "apiKey": "r3-local"
    },
    {
      "title": "⚡ r3/fast — gemma2:2b",
      "provider": "openai",
      "model": "r3/fast",
      "apiBase": "http://localhost:4000/v1",
      "apiKey": "r3-local"
    },
    {
      "title": "💬 r3/chat — mistral:latest",
      "provider": "openai",
      "model": "r3/chat",
      "apiBase": "http://localhost:4000/v1",
      "apiKey": "r3-local"
    },
    {
      "title": "💬 r3/chat-heavy — qwen2.5:14b",
      "provider": "openai",
      "model": "r3/chat-heavy",
      "apiBase": "http://localhost:4000/v1",
      "apiKey": "r3-local"
    },
    {
      "title": "📐 r3/large — mixtral 46.7B",
      "provider": "openai",
      "model": "r3/large",
      "apiBase": "http://localhost:4000/v1",
      "apiKey": "r3-local"
    },
    // ── Cloud Free-Tier Fallbacks ────────────────────────────
    {
      "title": "☁️ r3/code-fallback → Groq 70B",
      "provider": "openai",
      "model": "r3/code-fallback",
      "apiBase": "http://localhost:4000/v1",
      "apiKey": "r3-local"
    },
    {
      "title": "☁️ r3/large-alt → OpenRouter Auto",
      "provider": "openai",
      "model": "r3/large-alt",
      "apiBase": "http://localhost:4000/v1",
      "apiKey": "r3-local"
    },
    // ── Paid APIs (explicit request only) ───────────────────
    {
      "title": "💰 GPT-4o (via r3/gateway)",
      "provider": "openai",
      "model": "gpt-4o",
      "apiBase": "http://localhost:4000/v1",
      "apiKey": "r3-local"
    },
    {
      "title": "💰 Claude 3.5 Sonnet (via r3/gateway)",
      "provider": "openai",
      "model": "claude-3-5-sonnet",
      "apiBase": "http://localhost:4000/v1",
      "apiKey": "r3-local"
    }
  ],
  "continue.tabAutocompleteModel": {
    "title": "Autocomplete — r3/autocomplete (phi3:mini)",
    "provider": "openai",
    "model": "r3/autocomplete",
    "apiBase": "http://localhost:4000/v1",
    "apiKey": "r3-local"
  },
  "continue.enableTabAutocomplete": true,
  "continue.allowAnonymousTelemetry": false,
  "files.associations": {
    "*.json": "jsonc"
  },
  "editor.formatOnSave": false,

  // ── ACP (Agent Client Protocol) ─────────────────────────
  // GitHub Copilot CLI connects automatically when workspace is trusted.
  // Use /ide in CLI to manage VS Code connection + diff toggle.
  // ACP config: R3_LLM_ENGINE_REGISTRY/config/acp-config.json
  // providers/set routes ACP agent LLM calls → localhost:4000
  "github.copilot.advanced": {
    "debug.overrideProxyUrl": "http://localhost:4000/v1"
  },
  "github.copilot.chat.localeOverride": "de",
  "chat.agent.enabled": true,

  // ── R3 Platform Context ──────────────────────────────────
  // copilot-instructions.md gives Copilot Chat full R3 platform context.
  // Loaded automatically from .github/copilot-instructions.md in workspace root.
  "github.copilot.chat.codeGeneration.useInstructionFiles": true,
  "github.copilot.chat.testGeneration.useInstructionFiles": true
}
