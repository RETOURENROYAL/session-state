{
  "name": "R3 — Drive Secret Loader",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "hours", "hoursInterval": 6 }]
        }
      },
      "id": "cron-trigger",
      "name": "Alle 6h",
      "type": "n8n-nodes-base.scheduleTrigger",
      "position": [240, 300]
    },
    {
      "parameters": {
        "authentication": "serviceAccount",
        "operation": "list",
        "folderId": "1sZWT6d5AZgOnOR-_9ZF8Y2sNeid1kGQa",
        "fields": "id,name,modifiedTime",
        "orderBy": "modifiedTime desc"
      },
      "id": "gdrive-list",
      "name": "Drive: .env-aktuell listen",
      "type": "n8n-nodes-base.googleDrive",
      "credentials": { "googleApi": { "id": "r3-gdrive", "name": "R3 Google Drive" } },
      "position": [460, 300]
    },
    {
      "parameters": {
        "authentication": "serviceAccount",
        "operation": "download",
        "fileId": "={{ $json.id }}"
      },
      "id": "gdrive-download",
      "name": "Drive: .env herunterladen",
      "type": "n8n-nodes-base.googleDrive",
      "credentials": { "googleApi": { "id": "r3-gdrive", "name": "R3 Google Drive" } },
      "position": [680, 300]
    },
    {
      "parameters": {
        "jsCode": "const raw = Buffer.from(items[0].binary.data.data, 'base64').toString('utf8');\nconst secrets = {};\nraw.split('\\n').forEach(line => {\n  line = line.trim();\n  if (!line || line.startsWith('#')) return;\n  const idx = line.indexOf('=');\n  if (idx === -1) return;\n  const key = line.substring(0, idx).trim();\n  const val = line.substring(idx + 1).trim().replace(/^['\"]/,'').replace(/['\"]+$/,'');\n  secrets[key] = val;\n});\nreturn [{ json: secrets }];"
      },
      "id": "parse-env",
      "name": ".env parsen",
      "type": "n8n-nodes-base.code",
      "position": [900, 300]
    },
    {
      "parameters": {
        "url": "http://192.168.1.226:5678/webhook/secrets-update",
        "method": "POST",
        "jsonBody": "={{ JSON.stringify($json) }}",
        "options": {}
      },
      "id": "notify-stack",
      "name": "Stack benachrichtigen",
      "type": "n8n-nodes-base.httpRequest",
      "position": [1120, 300]
    },
    {
      "parameters": {
        "conditions": {
          "string": [{
            "value1": "={{ $json.SHOPIFY_API_KEY }}",
            "operation": "isNotEmpty"
          }]
        }
      },
      "id": "check-secrets",
      "name": "Secrets vollständig?",
      "type": "n8n-nodes-base.if",
      "position": [1120, 460]
    }
  ],
  "connections": {
    "Alle 6h": { "main": [[{ "node": "Drive: .env-aktuell listen", "type": "main", "index": 0 }]] },
    "Drive: .env-aktuell listen": { "main": [[{ "node": "Drive: .env herunterladen", "type": "main", "index": 0 }]] },
    "Drive: .env herunterladen": { "main": [[{ "node": ".env parsen", "type": "main", "index": 0 }]] },
    ".env parsen": { "main": [[{ "node": "Secrets vollständig?", "type": "main", "index": 0 }]] },
    "Secrets vollständig?": { "main": [[{ "node": "Stack benachrichtigen", "type": "main", "index": 0 }]] }
  },
  "settings": { "executionOrder": "v1" }
}
